# bom-web environment variables
# Copy to `.env.local` for local overrides (never committed).
# Vite picks up `.env.production` automatically when running `npm run build`.

# API base origin. Empty = relative paths "/api" + Vite dev-server proxy
# (default for `npm run dev`). For production set the full origin so the
# built bundle hits the deployed Fly.io API directly.
#
# Example for production:
#   VITE_API_BASE_URL=https://bom-fpf-api.fly.dev
VITE_API_BASE_URL=

# Web Push public VAPID key (must match backend's WebPush:VapidPublicKey).
# Without this, browser push subscription will be skipped silently.
# Generate via `npx web-push generate-vapid-keys` (one-time).
VITE_VAPID_PUBLIC_KEY=
